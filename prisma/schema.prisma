generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Client {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  phone     String?
  company   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  quotes Quote[]

  @@map("clients")
}

model Project {
  id          String      @id @default(cuid())
  title       String
  description String?
  category    ProjectType
  imageUrl    String?
  completedAt DateTime?
  featured    Boolean     @default(false)
  createdAt   DateTime    @default(now())

  @@map("projects")
}

model Quote {
  id          String      @id @default(cuid())
  clientId    String
  client      Client      @relation(fields: [clientId], references: [id])

  projectType ProjectType
  area        Float?
  location    String
  description String
  budget      Float?
  startDate   DateTime?

  estimatedMin Float?
  estimatedMax Float?
  status       QuoteStatus @default(PENDING)
  adminNotes   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("quotes")
}

enum ProjectType {
  RESIDENTIAL
  COMMERCIAL
  INDUSTRIAL
  RENOVATION
  INFRASTRUCTURE
}

enum QuoteStatus {
  PENDING
  REVIEWED
  SENT
  ACCEPTED
  REJECTED
}
